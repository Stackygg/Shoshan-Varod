---
import SectionTitle from '../ui/SectionTitle.astro';
import { getCategories } from '../../lib/wordpress';

const categories = await getCategories();

function getCategoryImage(slug: string) {
  if (slug.includes('accessoire')) return '/images/category_accessoires.png';
  if (slug.includes('manteau') || slug.includes('veste')) return '/images/category_manteaux.png';
  if (slug.includes('pantalon')) return '/images/category_pantalons.png';
  if (slug.includes('pull') || slug.includes('maille')) return '/images/category_pulls.png';
  if (slug.includes('robe')) return '/images/category_robes.png';
  if (slug.includes('sac')) return '/images/category_sacs.png';
  return null;
}
---

<section class="categories section" id="categories-section">
  <div class="container">
    <div class="reveal">
      <SectionTitle
        subtitle="Explorer"
        title="Nos univers"
      />
    </div>

    <div class="categories__grid">
      {categories.map((cat, i) => (
        <a
          href={`/boutique/?cat=${cat.slug}`}
          class={`categories__card reveal reveal--delay-${(i % 3) + 1}`}
          id={`category-${cat.slug}`}
        >
          <div class="categories__card-bg">
            {(() => {
              const imgSrc = getCategoryImage(cat.slug);
              if (imgSrc) {
                return <img src={imgSrc} alt={cat.name} class="categories__card-img" loading="lazy" />
              }
              return <div class="categories__card-gradient"></div>;
            })()}
          </div>
          <div class="categories__card-content">
            <h3 class="categories__card-name">{cat.name}</h3>
            <p class="categories__card-count">{cat.count} pièces</p>
          </div>
          <span class="categories__card-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .categories__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .categories__card {
    position: relative;
    display: flex;
    align-items: flex-start;
    min-height: 250px;
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .categories__card:hover {
    transform: translateY(-4px);
  }

  .categories__card-bg {
    position: absolute;
    inset: 0;
    background: var(--color-black-muted);
    overflow: hidden;
  }

  .categories__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .categories__card:hover .categories__card-img {
    transform: scale(1.05);
  }

  .categories__card-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(212, 160, 160, 0.08) 0%, transparent 60%);
  }

  .categories__card-content {
    position: relative;
    z-index: 1;
    margin: var(--space-md);
    padding: var(--space-xs) var(--space-md);
    background: rgba(212, 160, 160, 0.9); /* Rose Shoshan */
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  }

  .categories__card-name {
    font-family: var(--font-serif);
    font-size: var(--fs-md);
    font-weight: var(--fw-bold);
    color: var(--color-black);
    margin-bottom: 2px;
  }

  .categories__card-count {
    font-size: var(--fs-xs);
    color: rgba(44, 36, 32, 0.8);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
  }

  .categories__card-arrow {
    position: absolute;
    bottom: var(--space-md);
    right: var(--space-md);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(212, 160, 160, 0.95);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-black);
    opacity: 0;
    transform: translateY(10px) translateX(-10px);
    transition: all var(--duration-normal) var(--ease-out);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  }

  .categories__card:hover .categories__card-arrow {
    opacity: 1;
    transform: translateY(0) translateX(0);
  }

  /* Border glow on hover */
  .categories__card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md);
    border: 1px solid rgba(44, 36, 32, 0.05); /* Soft border for light theme */
    transition: border-color var(--duration-normal) var(--ease-out);
    z-index: 2;
    pointer-events: none;
  }

  .categories__card:hover::before {
    border-color: rgba(212, 160, 160, 0.4);
  }

  @media (max-width: 768px) {
    .categories__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .categories__grid {
      grid-template-columns: 1fr;
    }

    .categories__card {
      min-height: 160px;
    }
  }
</style>
